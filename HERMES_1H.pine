//@version=6
// ╔══════════════════════════════════════════════════════════════╗
// ║  HERMES 1H — Daily Breakout + Fib Bounce + Trend Pullback   ║
// ║  Apply to: 1-Hour chart                                     ║
// ║  Proven: Breakout +1992% backtest, Fib 73% profitable        ║
// ╚══════════════════════════════════════════════════════════════╝

strategy("Hermes 1H — Breakout + Fib", overlay=true,
     initial_capital=1000, default_qty_type=strategy.percent_of_equity,
     default_qty_value=50, commission_type=strategy.commission.percent, commission_value=0.1)

sl_pct     = input.float(2.0, "SL % (breakout)"); sl_fib = input.float(5.0, "SL % (fib)")
trail_wide = input.float(4.0, "Trail %"); trail_act = input.float(1.5, "Trail Activate %")
show_breakout = input.bool(true, "Daily Breakout", group="Signals")
show_fib      = input.bool(true, "Fib Bounce 0.618", group="Signals")
show_trend    = input.bool(true, "Trend Pullback", group="Signals")

// ═══════════════════════════════════════
// DAILY BREAKOUT — Range breakout
// ═══════════════════════════════════════
r_hi = ta.highest(high, 24)[1]; r_lo = ta.lowest(low, 24)[1]
db_vol = volume > ta.sma(volume,20)*1.2
db_long  = show_breakout and close>r_hi and close[1]<=r_hi and db_vol
db_short = show_breakout and close<r_lo and close[1]>=r_lo and db_vol

// ═══════════════════════════════════════
// FIB BOUNCE — 0.618 + ADX filter
// ═══════════════════════════════════════
sw_hi = ta.highest(high,100); sw_lo = ta.lowest(low,100)
f618_support = sw_hi - (sw_hi-sw_lo)*0.618
f618_resist  = sw_lo + (sw_hi-sw_lo)*0.618
[dp, dm, ax] = ta.dmi(14)
adx_ok = ax > 20
trend_up = adx_ok and dp > dm; trend_dn = adx_ok and dm > dp
ema50 = ta.ema(close,50)

fib_long  = show_fib and low<=f618_support*1.01 and low>=f618_support*0.99 and close>open and trend_up and close>ema50
fib_short = show_fib and high>=f618_resist*0.99 and high<=f618_resist*1.01 and close<open and trend_dn and close<ema50

// ═══════════════════════════════════════
// TREND PULLBACK — EMA 50 pullback in strong trend
// ═══════════════════════════════════════
ema21 = ta.ema(close,21)
pullback_up   = low <= ema21 and close > ema21 and trend_up and ta.rsi(close,14) < 55
pullback_down = high >= ema21 and close < ema21 and trend_dn and ta.rsi(close,14) > 45

trend_long  = show_trend and pullback_up and volume > ta.sma(volume,20)
trend_short = show_trend and pullback_down and volume > ta.sma(volume,20)

// ═══════════════════════════════════════
// EXECUTE — wider trail for 1H, fib gets more room
// ═══════════════════════════════════════
anyL = db_long or fib_long or trend_long
anyS = db_short or fib_short or trend_short

if db_long or trend_long
    strategy.entry("1L", strategy.long)
    strategy.exit("1LX","1L",stop=close*(1-sl_pct/100),
         trail_points=close*trail_wide/100/syminfo.mintick, trail_offset=close*trail_act/100/syminfo.mintick)
if fib_long
    strategy.entry("FL", strategy.long)
    strategy.exit("FLX","FL",stop=close*(1-sl_fib/100),
         trail_points=close*6/syminfo.mintick, trail_offset=close*2/100/syminfo.mintick)
if db_short or trend_short
    strategy.entry("1S", strategy.short)
    strategy.exit("1SX","1S",stop=close*(1+sl_pct/100),
         trail_points=close*trail_wide/100/syminfo.mintick, trail_offset=close*trail_act/100/syminfo.mintick)
if fib_short
    strategy.entry("FS", strategy.short)
    strategy.exit("FSX","FS",stop=close*(1+sl_fib/100),
         trail_points=close*6/syminfo.mintick, trail_offset=close*2/100/syminfo.mintick)

// Visuals
plotshape(db_long,"DB",shape.square,location.belowbar,color.green,size=size.small)
plotshape(db_short,"DB",shape.square,location.abovebar,color.red,size=size.small)
plotshape(fib_long,"F",shape.diamond,location.belowbar,color.teal,size=size.small)
plotshape(fib_short,"F",shape.diamond,location.abovebar,color.maroon,size=size.small)
plotshape(trend_long,"T",shape.triangleup,location.belowbar,color.blue,size=size.tiny)
plotshape(trend_short,"T",shape.triangledown,location.abovebar,color.orange,size=size.tiny)

plot(r_hi,"Range Hi",color.new(color.green,60),1)
plot(r_lo,"Range Lo",color.new(color.red,60),1)
plot(f618_support,"Fib .618",color.new(#ff9800,40),2)
plot(ema50,"EMA50",color.new(#9c27b0,30),2)
plot(ema21,"EMA21",color.new(#2196f3,30),1)

alertcondition(anyL,"1H LONG","LONG:{{ticker}}@{{close}} TF:1H")
alertcondition(anyS,"1H SHORT","SHORT:{{ticker}}@{{close}} TF:1H")
