//@version=6
// FIB BOUNCE — 0.618 retracement + ADX regime filter
// Exhaustive backtest winner: 73% profitable cross-validated
// Best settings: Fib 0.618, SL=5%, Trail=6%, ADX>20
//
// Alert webhook format for bot.py /tv endpoint

strategy("Fib Bounce 0.618", overlay=true,
     initial_capital=1000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100)

// ── Inputs ──
fib_level = input.float(0.618, "Fib Level", options=[0.382, 0.5, 0.618, 0.786])
sl_pct    = input.float(5.0, "SL %", step=0.5, tooltip="Wide SL for crypto volatility")
trail_pct = input.float(6.0, "Trail %", step=0.5, tooltip="Very wide — let winners breathe")
adx_min   = input.int(20, "Min ADX", minval=15, maxval=40)
lookback  = input.int(100, "Swing Lookback", minval=50)

// ── Swing High/Low ──
swing_high = ta.highest(high, lookback)
swing_low  = ta.lowest(low, lookback)
range = swing_high - swing_low

// ── Fib levels ──
fib_price = swing_high - range * fib_level   // for longs (bounce from fib support)
fib_resist = swing_low + range * fib_level   // for shorts (rejection from fib resistance)

// ── ADX trend strength ──
[diplus, diminus, adx] = ta.dmi(14)
trend_up   = adx > adx_min and diplus > diminus
trend_down = adx > adx_min and diminus > diplus

// ── Bounce detection ──
near_fib_support = low <= fib_price * 1.01 and low >= fib_price * 0.99 and close > open
near_fib_resist  = high >= fib_resist * 0.99 and high <= fib_resist * 1.01 and close < open

// ── Entry ──
long_signal  = near_fib_support and trend_up and close > ta.ema(close, 50)
short_signal = near_fib_resist and trend_down and close < ta.ema(close, 50)

// ── Wide trail ──
if long_signal
    strategy.entry("Fib Long", strategy.long)
    strategy.exit("Fib Trail L", "Fib Long",
         stop=close*(1-sl_pct/100),
         trail_points=close*trail_pct/100/syminfo.mintick,
         trail_offset=close*2.0/100/syminfo.mintick)

if short_signal
    strategy.entry("Fib Short", strategy.short)
    strategy.exit("Fib Trail S", "Fib Short",
         stop=close*(1+sl_pct/100),
         trail_points=close*trail_pct/100/syminfo.mintick,
         trail_offset=close*2.0/100/syminfo.mintick)

// ── Visuals ──
plot(fib_price, "Fib Support", color.new(color.green, 30), 2)
plot(fib_resist, "Fib Resist", color.new(color.red, 30), 2)
plot(ta.ema(close,50), "EMA 50", color.new(color.purple, 30), 1)

plotshape(long_signal,  "Long",  shape.triangleup,   location.belowbar, color.green, size=size.normal)
plotshape(short_signal, "Short", shape.triangledown, location.abovebar, color.red,   size=size.normal)

alertcondition(long_signal,  "FIB BOUNCE LONG",  "LONG: {{ticker}} fib {{plot_0}} @ {{close}}")
alertcondition(short_signal, "FIB BOUNCE SHORT", "SHORT: {{ticker}} fib rejection @ {{close}}")
