//@version=6
// DAILY BREAKOUT — 1H range breakout, trailing-only TP
// #1 Backtest Agent: +1,992% return, 909 trades, 74.5% WR
// Looks for breakout above/below prior day/week range
//
// Alert webhook format for bot.py /tv endpoint

strategy("Daily Breakout 1H", overlay=true,
     initial_capital=1000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100)

// ── Inputs ──
lookback  = input.int(24, "Lookback Bars (1H)", minval=8, maxval=168, tooltip="24 = 1 day of 1H bars")
sl_pct    = input.float(2.0, "SL %", step=0.5)
trail_pct = input.float(3.0, "Trail %", step=0.5, tooltip="Wide trail lets winners run")
trail_act = input.float(1.5, "Trail Activate %", step=0.5)

// ── Range ──
range_high = ta.highest(high, lookback)[1]
range_low  = ta.lowest(low, lookback)[1]

// ── Breakout ──
breakout_long  = close > range_high and close[1] <= range_high[1]
breakout_short = close < range_low and close[1] >= range_low[1]

// ── Volume ──
vol_avg = ta.sma(volume, 20)
vol_ok = volume > vol_avg * 1.2

// ── Entry ──
long_signal  = breakout_long and vol_ok
short_signal = breakout_short and vol_ok

// ── Trail exit ──
if long_signal
    strategy.entry("DB Long", strategy.long)
    strategy.exit("DB Trail L", "DB Long",
         stop=close*(1-sl_pct/100),
         trail_points=close*trail_pct/100/syminfo.mintick,
         trail_offset=close*trail_act/100/syminfo.mintick)

if short_signal
    strategy.entry("DB Short", strategy.short)
    strategy.exit("DB Trail S", "DB Short",
         stop=close*(1+sl_pct/100),
         trail_points=close*trail_pct/100/syminfo.mintick,
         trail_offset=close*trail_act/100/syminfo.mintick)

// ── Visuals ──
plot(range_high, "Range High", color.new(color.green, 60), 2)
plot(range_low,  "Range Low",  color.new(color.red, 60), 2)
plotshape(long_signal,  "Long",  shape.triangleup,   location.belowbar, color.green, size=size.normal)
plotshape(short_signal, "Short", shape.triangledown, location.abovebar, color.red,   size=size.normal)

alertcondition(long_signal,  "BREAKOUT LONG 1H",  "LONG: {{ticker}} breakout @ {{close}}")
alertcondition(short_signal, "BREAKOUT SHORT 1H", "SHORT: {{ticker}} breakdown @ {{close}}")
