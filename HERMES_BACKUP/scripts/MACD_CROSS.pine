//@version=6
// MACD CROSS — 15m primary + 5m confirm
// Backtest: +29% return, crypto-optimized MACD 24/52/18
// Live P&L: 31 trades, 71% WR, +$32.37 — ONLY proven live winner
//
// Alert webhook format for bot.py /tv endpoint

strategy("MACD Cross 15m+5m", overlay=true,
     initial_capital=1000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100)

// ── Inputs ──
sl_pct    = input.float(2.5, "SL %", step=0.5)
tp_rr     = input.float(3.0, "TP Risk:Reward", step=0.5, tooltip="TP = SL × RR")
min_vol   = input.float(1.8, "Min Volume Ratio", step=0.1)

// ── 15m Primary ──
fast_len = 24; slow_len = 52; sig_len = 18
[ml, ms, mh] = ta.macd(close, fast_len, slow_len, sig_len)
bull_cross = ml > ms and mh > mh[1] and ml[1] <= ms[1]
bear_cross = ml < ms and mh < mh[1] and ml[1] >= ms[1]

// Volume
vol_avg = ta.sma(volume, 20)
vol_ok = volume > vol_avg * min_vol

// ── 5m Confirm ──
close_5m = request.security(syminfo.tickerid, "5", close)
ema_5m_24 = ta.ema(close_5m, 24)
ema_5m_52 = ta.ema(close_5m, 52)
confirm_5m_bull = ema_5m_24 > ema_5m_52
confirm_5m_bear = ema_5m_24 < ema_5m_52

// ── Entry ──
long_signal  = bull_cross and vol_ok and confirm_5m_bull
short_signal = bear_cross and vol_ok and confirm_5m_bear

// ── SL/TP ──
sl_points = close * sl_pct / 100
tp_points_long  = close + sl_points * tp_rr
tp_points_short = close - sl_points * tp_rr

if long_signal
    strategy.entry("MACD Long", strategy.long)
    strategy.exit("XL", "MACD Long", stop=close-sl_points, limit=tp_points_long)

if short_signal
    strategy.entry("MACD Short", strategy.short)
    strategy.exit("XS", "MACD Short", stop=close+sl_points, limit=tp_points_short)

// ── Visuals ──
plotshape(long_signal,  "Long",  shape.triangleup,   location.belowbar, color.green, size=size.small)
plotshape(short_signal, "Short", shape.triangledown, location.abovebar, color.red,   size=size.small)

// ── EMA lines ──
plot(ta.ema(close,24), "EMA 24", color.new(#00bcd4,30), 2)
plot(ta.ema(close,52), "EMA 52", color.new(#ff9800,30), 2)

// ── MACD panel ──
hline(0, "Zero", color.gray)
plot(ml-ms, "Hist", style=plot.style_columns, color=ml>ms?color.green:color.red, display=display.all)

alertcondition(long_signal,  "MACD LONG 15m+5m",  "LONG: {{ticker}} @ {{close}}")
alertcondition(short_signal, "MACD SHORT 15m+5m", "SHORT: {{ticker}} @ {{close}}")
