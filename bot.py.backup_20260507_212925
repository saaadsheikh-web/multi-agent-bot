    More sensitive than plain RSI; better at catching exhaustion."""
    name = "stoch_rsi"
    enabled = True
    paper_only = False
    profile = "stoch_rsi"
    valid_regimes = ["RANGING", "VOLATILE"]

    PERIOD = 14
    LOW = 0.15
    HIGH = 0.85

    def analyze(self, sym, ctx):
        df = ctx.df_1h
        if len(df) < self.PERIOD * 3 + 5:
            return None
        c = df["close"]
        r = rsi(c, self.PERIOD)
        # Stochastic of RSI: (current - min) / (max - min) over period
        win = r.iloc[-self.PERIOD:]
        rmin = win.min(); rmax = win.max()
        if rmax - rmin <= 0 or pd.isna(rmax - rmin):
            return None
        stoch = (r.iloc[-1] - rmin) / (rmax - rmin)
        if pd.isna(stoch):
            return None
        last = c.iloc[-1]
        if stoch < self.LOW and r.iloc[-1] < 35:
            sl_price = last * 0.99
            tp_price = last * 1.015
            return Signal(self.name, sym, "long", 7, self.profile,
                          f"StochRSI long stoch={stoch:.2f} rsi={r.iloc[-1]:.0f}",
                          {"atr_sl": sl_price, "atr_tp": tp_price})
        if stoch > self.HIGH and r.iloc[-1] > 65:
            sl_price = last * 1.01
            tp_price = last * 0.985
            return Signal(self.name, sym, "short", 7, self.profile,
                          f"StochRSI short stoch={stoch:.2f} rsi={r.iloc[-1]:.0f}",
                          {"atr_sl": sl_price, "atr_tp": tp_price})
        return None


