class SupertrendAgent(Agent):
    notional_multiplier = 0.02
    """ATR-derived trailing stop on 1H. Long when supertrend flips bullish,
    short when it flips bearish. Classic, well-studied, low-noise."""
    name = "supertrend"
    enabled = True
    paper_only = False
    profile = "supertrend"
    valid_regimes = ["TRENDING"]

    ATR_PERIOD = 10
    ATR_MULT = 3.0

    def analyze(self, sym, ctx):
        df = ctx.df_1h
        if len(df) < 60:
            return None
        c = df["close"]; h = df["high"]; l = df["low"]
        last = c.iloc[-1]
        atr_now = atr(df, self.ATR_PERIOD).iloc[-1]
        if atr_now <= 0 or pd.isna(atr_now):
            return None
        hl2 = (h + l) / 2
        upper = (hl2 + self.ATR_MULT * atr_now).iloc[-1]
        lower = (hl2 - self.ATR_MULT * atr_now).iloc[-1]
        # Crude flip detection: previous close vs current bands
        prev_close = c.iloc[-2]
        flipped_long = prev_close < lower and last > lower
        flipped_short = prev_close > upper and last < upper
        if flipped_long:
            sl_price = last - self.ATR_MULT * atr_now
            tp_price = last * 1.99
            return Signal(self.name, sym, "long", 8, self.profile,
                          f"supertrend flip long, ATR {atr_now:.4f}",
                          {"atr_sl": sl_price, "atr_tp": tp_price, "atr_val": atr_now})
        if flipped_short:
            sl_price = last + self.ATR_MULT * atr_now
            tp_price = last * 0.01
            return Signal(self.name, sym, "short", 8, self.profile,
                          f"supertrend flip short, ATR {atr_now:.4f}",
                          {"atr_sl": sl_price, "atr_tp": tp_price, "atr_val": atr_now})
        return None


