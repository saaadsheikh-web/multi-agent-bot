                    regime = "TRENDING"
                elif adx_val < 20:
                    regime = "RANGING"
                elif atr_avg > 0 and atr_val > 2 * atr_avg:
                    regime = "VOLATILE"
                else:
                    regime = "RANGING"
                state.regime = regime
                log.info(f"regime: {regime}  ADX={adx_val:.1f}  ATR={atr_val:.2f}")
        except Exception as e:
            log.warning(f"regime_loop: {e}")
        await asyncio.sleep(900)  # 15 min


