//@version=6
// ╔══════════════════════════════════════════════════════════════╗
// ║              HERMES MASTER — Multi-TF Engine                 ║
// ║  5 Timeframes × 6 Indicators × Weighted Consensus            ║
// ║  Any pair, any exchange — just load and go                   ║
// ╚══════════════════════════════════════════════════════════════╝

strategy("Saad Bot 007", overlay=true, max_lines_count=500, max_labels_count=500,
     initial_capital=1000, default_qty_type=strategy.percent_of_equity, default_qty_value=25,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════

// Risk
slPct      = input.float(2.5, "SL %",              step=0.5, group="Risk")
trailDist  = input.float(3.0, "Trail Distance %",  step=0.5, group="Risk")
trailAct   = input.float(1.0, "Trail Activates %", step=0.1, group="Risk")

// Signal
minConsensus = input.int(3, "Indicators Required", minval=2, maxval=6, group="Signal")
minTFs       = input.int(2, "TFs Must Agree",      minval=1, maxval=5, group="Signal")
minScore     = input.float(50, "Min Score",         minval=30, maxval=80, step=5, group="Signal")

// Timeframes
use5m  = input.bool(true, "5m",  group="Timeframes")
use15m = input.bool(true, "15m", group="Timeframes")
use30m = input.bool(true, "30m", group="Timeframes")
use1h  = input.bool(true, "1H",  group="Timeframes")
use4h  = input.bool(true, "4H",  group="Timeframes")

// Weights
wRSI = input.float(1.0, "RSI",     minval=0.0, maxval=3.0, step=0.1, group="Weights")
wMACD= input.float(1.5, "MACD",    minval=0.0, maxval=3.0, step=0.1, group="Weights")
wBB  = input.float(1.0, "BB",      minval=0.0, maxval=3.0, step=0.1, group="Weights")
wEMA = input.float(1.2, "EMA",     minval=0.0, maxval=3.0, step=0.1, group="Weights")
wFIB = input.float(1.3, "Fib",     minval=0.0, maxval=3.0, step=0.1, group="Weights")
wVOL = input.float(0.8, "Volume",  minval=0.0, maxval=3.0, step=0.1, group="Weights")

// ═══════════════════════════════════════════════════════════════
// COMPOSITE SIGNAL FUNCTION — runs on each TF independently
// ═══════════════════════════════════════════════════════════════

f_signal(close, high, low, volume, tfName) =>

    // 1. RSI (14)
    r = ta.rsi(close, 14)
    rsiL = math.max(0.0, math.min(100.0, (40.0 - r) * 5.0))
    rsiS = math.max(0.0, math.min(100.0, (r - 60.0) * 5.0))

    // 2. MACD (24/52/18) — crypto optimized
    [ml, ms, mh] = ta.macd(close, 24, 52, 18)
    mBull = ml > ms and mh > mh[1]
    mBear = ml < ms and mh < mh[1]
    macdL = mBull ? 100.0 : 0.0
    macdS = mBear ? 100.0 : 0.0

    // 3. Bollinger Bands (20,2)
    bbBasis = ta.sma(close, 20)
    bbDev   = ta.stdev(close, 20) * 2.0
    bbUpper = bbBasis + bbDev
    bbLower = bbBasis - bbDev
    bbPos   = (close - bbLower) / (bbUpper - bbLower)
    bbL = math.max(0.0, math.min(100.0, (1.0 - bbPos) * 100.0))
    bbS = math.max(0.0, math.min(100.0, bbPos * 100.0))

    // 4. EMA Stack (9/21/50)
    e9  = ta.ema(close, 9)
    e21 = ta.ema(close, 21)
    e50 = ta.ema(close, 50)
    emaBull = e9 > e21 and e21 > e50
    emaBear = e9 < e21 and e21 < e50
    emaL = emaBull ? 100.0 : (e9 > e21 ? 50.0 : 0.0)
    emaS = emaBear ? 100.0 : (e9 < e21 ? 50.0 : 0.0)

    // 5. Fibonacci (0.382 / 0.5 / 0.618)
    swHi = ta.highest(high, 100)
    swLo = ta.lowest(low, 100)
    rng  = swHi - swLo
    f382 = swLo + rng * 0.382
    f500 = swLo + rng * 0.500
    f618 = swLo + rng * 0.618
    fibL = close <= f500 * 1.01 and close >= f382 * 0.99 ? 100.0 : (close < f500 ? 60.0 : 0.0)
    fibS = close >= f500 * 0.99 and close <= f618 * 1.01 ? 100.0 : (close > f500 ? 60.0 : 0.0)

    // 6. Volume
    vAvg = ta.sma(volume, 20)
    vScore = math.min(100.0, volume / vAvg * 50.0)

    // Weighted Consensus
    tw = wRSI + wMACD + wBB + wEMA + wFIB + wVOL
    scoreL = (rsiL*wRSI + macdL*wMACD + bbL*wBB + emaL*wEMA + fibL*wFIB + vScore*wVOL) / tw
    scoreS = (rsiS*wRSI + macdS*wMACD + bbS*wBB + emaS*wEMA + fibS*wFIB + vScore*wVOL) / tw

    agreesL = (rsiL>50?1:0) + (macdL>50?1:0) + (bbL>50?1:0) + (emaL>50?1:0) + (fibL>50?1:0) + (vScore>50?1:0)
    agreesS = (rsiS>50?1:0) + (macdS>50?1:0) + (bbS>50?1:0) + (emaS>50?1:0) + (fibS>50?1:0) + (vScore>50?1:0)

    longSig  = scoreL >= minScore and agreesL >= minConsensus and scoreL > scoreS
    shortSig = scoreS >= minScore and agreesS >= minConsensus and scoreS > scoreL

    [longSig, shortSig, scoreL, scoreS, agreesL, agreesS, e50]

// ═══════════════════════════════════════════════════════════════
// MULTI-TF DATA — pull from each timeframe
// ═══════════════════════════════════════════════════════════════

// 5m
[c5, h5, l5, v5] = request.security(syminfo.tickerid, "5",  [close, high, low, volume], lookahead=barmerge.lookahead_off)
[L5, S5, sL5, sS5, aL5, aS5, e5]   = f_signal(c5, h5, l5, v5, "5m")

// 15m
[c15, h15, l15, v15] = request.security(syminfo.tickerid, "15", [close, high, low, volume], lookahead=barmerge.lookahead_off)
[L15, S15, sL15, sS15, aL15, aS15, e15] = f_signal(c15, h15, l15, v15, "15m")

// 30m
[c30, h30, l30, v30] = request.security(syminfo.tickerid, "30", [close, high, low, volume], lookahead=barmerge.lookahead_off)
[L30, S30, sL30, sS30, aL30, aS30, e30] = f_signal(c30, h30, l30, v30, "30m")

// 1H
[c60, h60, l60, v60] = request.security(syminfo.tickerid, "60", [close, high, low, volume], lookahead=barmerge.lookahead_off)
[L60, S60, sL60, sS60, aL60, aS60, e60] = f_signal(c60, h60, l60, v60, "1H")

// 4H
[c240, h240, l240, v240] = request.security(syminfo.tickerid, "240", [close, high, low, volume], lookahead=barmerge.lookahead_off)
[L240, S240, sL240, sS240, aL240, aS240, e240] = f_signal(c240, h240, l240, v240, "4H")

// ═══════════════════════════════════════════════════════════════
// MULTI-TF CONFLUENCE GATE
// ═══════════════════════════════════════════════════════════════

tfsLong  = (use5m and L5?1:0) + (use15m and L15?1:0) + (use30m and L30?1:0) + (use1h and L60?1:0) + (use4h and L240?1:0)
tfsShort = (use5m and S5?1:0) + (use15m and S15?1:0) + (use30m and S30?1:0) + (use1h and S60?1:0) + (use4h and S240?1:0)

anyLong  = tfsLong  >= minTFs
anyShort = tfsShort >= minTFs

// ═══════════════════════════════════════════════════════════════
// ENTRY + EXIT
// ═══════════════════════════════════════════════════════════════

if anyLong
    strategy.entry("L", strategy.long)
    strategy.exit("LX", "L",
         stop         = close * (1.0 - slPct / 100.0),
         trail_points = close * trailDist / 100.0 / syminfo.mintick,
         trail_offset = close * trailAct / 100.0 / syminfo.mintick)

if anyShort
    strategy.entry("S", strategy.short)
    strategy.exit("SX", "S",
         stop         = close * (1.0 + slPct / 100.0),
         trail_points = close * trailDist / 100.0 / syminfo.mintick,
         trail_offset = close * trailAct / 100.0 / syminfo.mintick)

// ═══════════════════════════════════════════════════════════════
// VISUALS — Unique shape per timeframe
// ═══════════════════════════════════════════════════════════════

// EMA 50
plot(ta.ema(close, 50), "EMA50", color.new(#9c27b0, 40), 2)

// 5m — tiny circles
plotshape(use5m and L5,  "5mL", shape.circle,        location.belowbar, color.new(#00ff00, 20), size=size.tiny)
plotshape(use5m and S5,  "5mS", shape.circle,        location.abovebar, color.new(#ff0000, 20), size=size.tiny)

// 15m — small triangles
plotshape(use15m and L15,"15L", shape.triangleup,    location.belowbar, color.new(#00ff00, 40), size=size.small)
plotshape(use15m and S15,"15S", shape.triangledown,  location.abovebar, color.new(#ff0000, 40), size=size.small)

// 30m — diamonds
plotshape(use30m and L30,"30L", shape.diamond,       location.belowbar, color.new(#00bcd4, 50), size=size.small)
plotshape(use30m and S30,"30S", shape.diamond,       location.abovebar, color.new(#ff9800, 50), size=size.small)

// 1H — squares
plotshape(use1h and L60, "1HL", shape.square,        location.belowbar, color.green, size=size.normal)
plotshape(use1h and S60, "1HS", shape.square,        location.abovebar, color.red,   size=size.normal)

// 4H — flags
plotshape(use4h and L240,"4HL", shape.flag,          location.belowbar, color.new(#008000, 0), size=size.large)
plotshape(use4h and S240,"4HS", shape.flag,          location.abovebar, color.new(#800000, 0), size=size.large)

// Multi-TF confirmed — huge arrow with label
plotshape(anyLong,  "GO LONG",  shape.triangleup,   location.belowbar, color.green, size=size.huge)
plotshape(anyShort, "GO SHORT", shape.triangledown, location.abovebar, color.red,   size=size.huge)

// ═══════════════════════════════════════════════════════════════
// DASHBOARD TABLE — bottom right, TF consensus at a glance
// ═══════════════════════════════════════════════════════════════

var table dash = table.new(position.bottom_right, 4, 6, border_width=1, border_color=#333333, bgcolor=#1a1a1acc, frame_color=#555555, frame_width=1)

if barstate.islast
    // Header
    table.cell(dash, 0,0, "TF",    text_color=color.white, bgcolor=#333333)
    table.cell(dash, 1,0, "LONG",  text_color=color.white, bgcolor=#333333)
    table.cell(dash, 2,0, "SHORT", text_color=color.white, bgcolor=#333333)
    table.cell(dash, 3,0, "OK",    text_color=color.white, bgcolor=#333333)

    f_row(col, tf, sL, sS, aL, aS, active) =>
        cL = sL > sS and sL >= minScore ? color.green : color.gray
        cS = sS > sL and sS >= minScore ? color.red   : color.gray
        bg = active ? #222222 : na
        table.cell(dash, 0, col, tf,                       text_color=color.white, bgcolor=bg)
        table.cell(dash, 1, col, str.tostring(math.round(sL)), text_color=cL,         bgcolor=bg)
        table.cell(dash, 2, col, str.tostring(math.round(sS)), text_color=cS,         bgcolor=bg)
        table.cell(dash, 3, col, str.tostring(aL) + "/" + str.tostring(aS), text_color=color.white, bgcolor=bg)

    f_row(1, "5m",  sL5,  sS5,  aL5,  aS5,  use5m)
    f_row(2, "15m", sL15, sS15, aL15, aS15, use15m)
    f_row(3, "30m", sL30, sS30, aL30, aS30, use30m)
    f_row(4, "1H",  sL60, sS60, aL60, aS60, use1h)
    f_row(5, "4H",  sL240, sS240, aL240, aS240, use4h)

// ═══════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════

alertcondition(anyLong,  "Saad Bot 007 LONG",  "LONG {{ticker}} @ {{close}}")
alertcondition(anyShort, "Saad Bot 007 SHORT", "SHORT {{ticker}} @ {{close}}")
